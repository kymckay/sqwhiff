{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "cppbuild",
      "label": "GCC: Build",
      "command": "bazel",
      "args": ["build", "--config", "gcc", "//sqwhiff"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$msCompile"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "cppbuild",
      "label": "GCC: Build Debug",
      "command": "bazel",
      "args": ["build", "--config", "gcc:debug", "//sqwhiff"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$msCompile"],
      "group": "build"
    },
    {
      "type": "cppbuild",
      "label": "GCC: Test",
      "command": "bazel",
      "args": ["test", "--config", "gcc", "//..."],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$msCompile"],
      "group": "test"
    },
    {
      "type": "cppbuild",
      "label": "MSVC: Build",
      "command": "bazel",
      "args": ["build", "--config", "msvc", "//sqwhiff"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$msCompile"],
      "group": "build"
    },
    {
      "type": "cppbuild",
      "label": "MSVC: Test",
      "command": "bazel",
      "args": ["test", "--config", "msvc", "//..."],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$msCompile"],
      "group": "test"
    },
  ]
}
